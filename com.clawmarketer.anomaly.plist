<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.clawmarketer.anomaly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/muhammadegaa/.openclaw/workspace/skills/clawmarketer-anomaly/agent.py</string>
    </array>

    <!-- Run every 4 hours: 6am, 10am, 2pm, 6pm, 10pm -->
