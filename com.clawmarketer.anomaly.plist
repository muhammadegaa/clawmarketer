    </array>

    <key>StandardOutPath</key>
    <string>/Users/muhammadegaa/.openclaw/logs/anomaly_alerter.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/muhammadegaa/.openclaw/logs/anomaly_alerter.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
